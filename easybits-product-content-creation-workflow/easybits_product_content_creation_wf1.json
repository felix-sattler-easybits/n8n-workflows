      "id": "d822152a-d424-4ea4-ae4a-571e98afd5c9",
      "name": "Build WF2 Payload"
    },
    {
      "parameters": {
        "jsCode": "// Grab the incoming webhook data\nconst webhookData = $input.first().json;\nconst body = webhookData.body || {};\nconst binary = $input.first().binary || {};\n\n// Generate a unique submission ID\n// Format: SUB-{timestamp}-{random4} — easy to read and sort\nconst timestamp = new Date();\nconst dateStr = timestamp.toISOString().slice(0, 10).replace(/-/g, '');\nconst timeStr = timestamp.toISOString().slice(11, 19).replace(/:/g, '');\nconst randomSuffix = Math.random().toString(36).slice(2, 6).toUpperCase();\nconst submissionId = `SUB-${dateStr}-${timeStr}-${randomSuffix}`;\n\n// Take inventory of uploaded files\n// Binary properties come in as keys on the binary object\nconst fileInventory = [];\nfor (const [key, fileData] of Object.entries(binary)) {\n  fileInventory.push({\n    binaryKey: key,\n    filename: fileData.fileName || 'unnamed',\n    mimeType: fileData.mimeType || 'unknown',\n    fileSize: fileData.fileSize || 0,\n  });\n}\n\n// Build the clean, flattened output\nreturn {\n  json: {\n    submissionId: submissionId,\n    receivedAt: timestamp.toISOString(),\n    skuId: body.sku_id || null,\n    category: body.category || null,\n    brand: body.brand || null,\n    notes: body.notes || null,\n    fileCount: fileInventory.length,\n    files: fileInventory,\n  },\n  binary: binary,\n  pairedItem: { item: 0 },\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -16,
        0
      ],
      "id": "f42ac37a-1d84-4d17-9e74-fed7b5b89400",
      "name": "Parse Submission"
    },
    {
      "parameters": {
        "jsCode": "// Pull the original submission data and binaries from Node 2\nconst submission = $('Parse Submission').item.json;\nconst binary = $('Parse Submission').item.binary || {};\n\n// Define routing rules by MIME type\nconst EXTRACTOR_MIMES = [\n  'application/pdf',\n  'image/png',\n  'image/jpeg',\n  'image/jpg',\n];\nconst EXCEL_MIMES = [\n  'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',\n  'application/vnd.ms-excel',\n  'text/csv',\n];\n\n// Buckets we'll fill as we walk the binaries\nconst specFilesForExtractor = [];\nconst specFilesForExcel = [];\nconst productImages = [];\n\nfor (const [key, fileData] of Object.entries(binary)) {\n  const mime = (fileData.mimeType || '').toLowerCase();\n  const filename = fileData.fileName || 'unnamed';\n  const isProductImage = key.startsWith('product_images');\n  const isSpecFile = key.startsWith('spec_files');\n\n  const fileMeta = {\n    binaryKey: key,\n    filename: filename,\n    mimeType: mime,\n  };\n\n  if (isProductImage) {\n    // Product images go to Workflow 2 — we just note them\n    productImages.push(fileMeta);\n  } else if (isSpecFile) {\n    // Spec files split by type\n    if (EXTRACTOR_MIMES.includes(mime)) {\n      specFilesForExtractor.push(fileMeta);\n    } else if (EXCEL_MIMES.includes(mime)) {\n      specFilesForExcel.push(fileMeta);\n    } else {\n      // Unknown spec file type — log but don't route\n      specFilesForExtractor.push({ ...fileMeta, warning: 'unknown_mime' });\n    }\n  }\n}\n\n// Build output items: one item per file that needs processing in W1\n// Each carries its own binary so downstream branches can act on it\nconst outputItems = [];\n\n// Extractor branch items\nfor (const file of specFilesForExtractor) {\n  outputItems.push({\n    json: {\n      submissionId: submission.submissionId,\n      route: 'extractor',\n      filename: file.filename,\n      mimeType: file.mimeType,\n    },\n    binary: {\n      data: binary[file.binaryKey],\n    },\n    pairedItem: { item: 0 },\n  });\n}\n\n// Excel branch items\nfor (const file of specFilesForExcel) {\n  outputItems.push({\n    json: {\n      submissionId: submission.submissionId,\n      route: 'excel',\n      filename: file.filename,\n      mimeType: file.mimeType,\n    },\n    binary: {\n      data: binary[file.binaryKey],\n    },\n    pairedItem: { item: 0 },\n  });\n}\n\n// Also output a summary item so we know what was routed where\n// We'll use this in the consolidation step later\noutputItems.push({\n  json: {\n    submissionId: submission.submissionId,\n    route: 'summary',\n    extractorCount: specFilesForExtractor.length,\n    excelCount: specFilesForExcel.length,\n    productImageCount: productImages.length,\n    productImages: productImages,\n  },\n  pairedItem: { item: 0 },\n});\n\nreturn outputItems;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1504,
        -96
      ],
      "id": "299eb7b7-1bf8-4e38-9545-463333e4f37b",
      "name": "Route Files"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nconst formBrand = String($('Parse Submission').first().json.brand || '').trim();\nconst specRan = $('Consolidate Specs').isExecuted;\nconst spec = specRan ? $('Consolidate Specs').first().json.consolidatedSpec || {} : {};\nconst extractedBrand = spec.brand ? String(spec.brand).trim() : '';\n\nconst finalBrand = formBrand || extractedBrand || null;\n\nreturn [{\n  json: {\n    ...input,\n    consolidatedSpec: {\n      ...spec,\n      brand: finalBrand,\n      product_name: spec.product_name || '',\n      key_features: spec.key_features || [],\n      materials: spec.materials || [],\n      color_options: spec.color_options || [],\n      size_options: spec.size_options || [],\n    },\n  },\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
