    {
      "parameters": {
        "jsCode": "// Pull the original submission data from the Code node (Node 2)\nconst submission = $('Parse Submission').item.json;\nconst binary = $('Parse Submission').item.binary || {};\n\n// Create one output item per file, each carrying its own binary\nconst items = [];\nfor (const [key, fileData] of Object.entries(binary)) {\n  items.push({\n    json: {\n      submissionId: submission.submissionId,\n      binaryKey: key,\n      filename: fileData.fileName || 'unnamed',\n      mimeType: fileData.mimeType,\n    },\n    binary: {\n      data: fileData,\n    },\n    pairedItem: { item: 0 },\n  });\n}\n\n// If no files came in, emit a single marker item so the run continues\nif (items.length === 0) {\n  return [{\n    json: {\n      submissionId: submission.submissionId,\n      notes: submission.notes || '',\n      noFiles: true,\n    },\n    pairedItem: { item: 0 },\n  }];\n}\n\nreturn items;"
      },
