    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const extractorOutput = $input.item.json;\n\n// The Extractor wraps results in a 'data' envelope\nconst rawSpec = extractorOutput.data || {};\n\n// Helper: convert the Extractor's \"null\" string into actual null\nfunction cleanNull(value) {\n  if (value === 'null' || value === null || value === undefined || value === '') {\n    return null;\n  }\n  return value;\n}\n\n// Helper: clean array fields (catch \"null\" string inside arrays, drop empties)\nfunction cleanArray(value) {\n  if (!Array.isArray(value)) return [];\n  return value\n    .filter((v) => v !== 'null' && v !== null && v !== undefined && v !== '')\n    .map((v) => String(v).trim());\n}\n\n// Normalize the spec object: strings get cleanNull, arrays get cleanArray\nconst spec = {\n  product_name: cleanNull(rawSpec.product_name),\n  brand: cleanNull(rawSpec.brand),\n  short_description: cleanNull(rawSpec.short_description),\n  key_features: cleanArray(rawSpec.key_features),\n  materials: cleanArray(rawSpec.materials),\n  dimensions: cleanNull(rawSpec.dimensions),\n  weight: cleanNull(rawSpec.weight),\n  color_options: cleanArray(rawSpec.color_options),\n  size_options: cleanArray(rawSpec.size_options),\n  model_number: cleanNull(rawSpec.model_number),\n};\n\nreturn {\n  json: {\n    submissionId: $('Route Files').item.json.submissionId,\n    source: 'extractor',\n    sourceFilename: $('Route Files').item.json.filename || 'unknown',\n    data: spec,\n  },\n  pairedItem: $input.item.pairedItem,\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2160,
        -288
      ],
      "id": "853f3f2c-fe81-44bd-b740-8207a0ab1256",
      "name": "Wrap Extractor Output"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const row = $input.item.json;\n\n// Helper: normalize column header lookup (case-insensitive, trim spaces, underscores or hyphens)\nfunction getField(row, ...possibleNames) {\n  const normalize = (s) => s.toLowerCase().replace(/[\\s_-]+/g, '');\n  const rowKeys = Object.keys(row);\n  for (const name of possibleNames) {\n    const target = normalize(name);\n    const match = rowKeys.find((k) => normalize(k) === target);\n    if (match && row[match] !== null && row[match] !== undefined && row[match] !== '') {\n      return String(row[match]).trim();\n    }\n  }\n  return null;\n}\n\n// Helper: split a comma-separated string into a clean array\nfunction splitToArray(value) {\n  if (!value) return [];\n  return value\n    .split(/[,;|]/)\n    .map((s) => s.trim())\n    .filter((s) => s.length > 0);\n}\n\n// Map Excel columns to spec schema, tolerating common header variations\nconst spec = {\n  product_name: getField(row, 'product_name', 'product name', 'name', 'title'),\n  brand: getField(row, 'brand', 'manufacturer', 'make'),\n  short_description: getField(row, 'short_description', 'description', 'summary'),\n  key_features: splitToArray(getField(row, 'key_features', 'features', 'highlights')),\n  materials: splitToArray(getField(row, 'materials', 'material', 'composition')),\n  dimensions: getField(row, 'dimensions', 'size', 'measurements'),\n  weight: getField(row, 'weight', 'mass'),\n  color_options: splitToArray(getField(row, 'color_options', 'colors', 'colour_options', 'colours')),\n  size_options: splitToArray(getField(row, 'size_options', 'sizes', 'variants')),\n  model_number: getField(row, 'model_number', 'model', 'sku', 'product_code', 'item_code'),\n};\n\nreturn {\n  json: {\n    submissionId: $('Route Files').item.json.submissionId,\n    source: 'excel',\n    sourceFilename: $('Route Files').item.json.filename || 'unknown.xlsx',\n    data: spec,\n  },\n  pairedItem: $input.item.pairedItem,\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2160,
        -96
      ],
      "id": "3ac3498d-5de8-4393-a1a0-fdd2bbbcf152",
      "name": "Map Excel to Spec"
    },
    {
      "parameters": {},
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3.2,
      "position": [
        2416,
        -192
      ],
      "id": "46b51683-b5a0-44bc-a03a-01e8dbadd877",
      "name": "Merge – Combine Extractor and Excel branches"
    },
    {
      "parameters": {
        "jsCode": "const allSpecItems = $input.all();\n\n// If nothing came through (no spec files at all), exit gracefully\nif (allSpecItems.length === 0) {\n  return [{\n    json: {\n      submissionId: $('Parse Submission').item.json.submissionId,\n      consolidatedSpec: null,\n      sourceMap: {},\n      sourceCount: 0,\n      warning: 'no_spec_files_received',\n    },\n    pairedItem: { item: 0 },\n  }];\n}\n\n// Initialize the consolidated spec — all fields start as null/empty\nconst consolidated = {\n  product_name: null,\n  brand: null,\n  short_description: null,\n  key_features: [],\n  materials: [],\n  dimensions: null,\n  weight: null,\n  color_options: [],\n  size_options: [],\n  model_number: null,\n};\n\n// Track which source filled which field (for traceability)\nconst sourceMap = {};\n\n// Priority: Extractor results take precedence over Excel for scalar fields\n// (Extractor reads PDFs which typically have more authoritative spec data)\n// Arrays get unioned across all sources, then deduplicated\nconst sortedItems = allSpecItems.slice().sort((a, b) => {\n  const aPriority = a.json.source === 'extractor' ? 0 : 1;\n  const bPriority = b.json.source === 'extractor' ? 0 : 1;\n  return aPriority - bPriority;\n});\n\n// Walk through each source spec\nfor (const item of sortedItems) {\n  const spec = item.json.data || {};\n  const sourceLabel = `${item.json.source}:${item.json.sourceFilename}`;\n\n  // Scalar fields: first non-null wins (Extractor runs first due to sort)\n  const scalarFields = ['product_name', 'brand', 'short_description', 'dimensions', 'weight', 'model_number'];\n  for (const field of scalarFields) {\n    if (consolidated[field] === null && spec[field] !== null && spec[field] !== undefined) {\n      consolidated[field] = spec[field];\n      sourceMap[field] = sourceLabel;\n    }\n  }\n\n  // Array fields: union across all sources\n  const arrayFields = ['key_features', 'materials', 'color_options', 'size_options'];\n  for (const field of arrayFields) {\n    if (Array.isArray(spec[field]) && spec[field].length > 0) {\n      consolidated[field] = [...consolidated[field], ...spec[field]];\n      // Track contributors\n      if (!sourceMap[field]) sourceMap[field] = [];\n      sourceMap[field].push(sourceLabel);\n    }\n  }\n}\n\n// Deduplicate arrays (case-insensitive)\nfor (const field of ['key_features', 'materials', 'color_options', 'size_options']) {\n  const seen = new Set();\n  consolidated[field] = consolidated[field].filter((v) => {\n    const lower = v.toLowerCase();\n    if (seen.has(lower)) return false;\n    seen.add(lower);\n    return true;\n  });\n}\n\nreturn [{\n  json: {\n    submissionId: $('Parse Submission').item.json.submissionId,\n    consolidatedSpec: consolidated,\n    sourceMap: sourceMap,\n    sourceCount: allSpecItems.length,\n  },\n  pairedItem: { item: 0 },\n}];"
      },
