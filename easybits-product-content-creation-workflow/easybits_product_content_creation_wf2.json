    {
      "parameters": {
        "jsCode": "// Get the extracted data and normalize \"null\" strings to real null\nconst extracted = $json.data || {};\nconst cleaned = {};\n\nfor (const [key, value] of Object.entries(extracted)) {\n  if (value === 'null') {\n    cleaned[key] = null;\n  } else if (Array.isArray(value)) {\n    // Filter out any \"null\" strings from arrays too\n    cleaned[key] = value.filter(v => v !== 'null');\n  } else {\n    cleaned[key] = value;\n  }\n}\n\n// Pull metadata from the Expand Image Items node so we know which image this is\nconst imageMeta = $('Expand Image Items').item.json;\n\nreturn {\n  json: {\n    submissionId: imageMeta.submissionId,\n    submissionFolderId: imageMeta.submissionFolderId,\n    consolidatedSpec: imageMeta.consolidatedSpec,\n    notes: imageMeta.notes,\n    imageIndex: imageMeta.imageIndex,\n    filename: imageMeta.filename,\n    imageAttributes: cleaned,\n    source: 'extractor',\n  },\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1248,
        80
      ],
      "id": "b66edf8e-c6ad-4cbe-9827-de23dde58472",
      "name": "Wrap Image Extraction Output"
    },
    {
      "parameters": {
        "jsCode": "// Gather all per-image results from the loop\nconst allItems = $input.all();\n\n// Handle the no-images case (Expand Image Items returned a single noImages marker)\nif (allItems.length === 1 && allItems[0].json.noImages === true) {\n  const meta = allItems[0].json;\n  return [{\n    json: {\n      submissionId: meta.submissionId,\n      submissionFolderId: meta.submissionFolderId,\n      consolidatedSpec: meta.consolidatedSpec,\n      notes: meta.notes,\n      imageData: [],\n      imageCount: 0,\n    },\n    pairedItem: { item: 0 },\n  }];\n}\n\n// Pull shared metadata from the first item (same across all images in this submission)\nconst first = allItems[0].json;\nconst submissionId = first.submissionId;\nconst submissionFolderId = first.submissionFolderId;\nconst consolidatedSpec = first.consolidatedSpec;\nconst notes = first.notes;\n\n// Build the imageData array - one entry per image, sorted by imageIndex\nconst imageData = allItems\n  .map(item => ({\n    index: item.json.imageIndex,\n    filename: item.json.filename,\n    attributes: item.json.imageAttributes,\n  }))\n  .sort((a, b) => a.index - b.index);\n\nreturn [{\n  json: {\n    submissionId: submissionId,\n    submissionFolderId: submissionFolderId,\n    consolidatedSpec: consolidatedSpec,\n    notes: notes,\n    imageData: imageData,\n    imageCount: imageData.length,\n  },\n  pairedItem: { item: 0 },\n}];"
      },
      "type": "n8n-nodes-base.code",
