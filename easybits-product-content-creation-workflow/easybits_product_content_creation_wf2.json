    {
      "parameters": {
        "jsCode": "// Pull inputs from the trigger\nconst trigger = $input.first().json;\nconst submissionId = trigger.submissionId;\nconst submissionFolderId = trigger.submissionFolderId;\nconst productImages = trigger.productImages || [];\nconst consolidatedSpec = trigger.consolidatedSpec;\nconst notes = trigger.notes;\n\n// If no images came in, return a single summary item so the loop just skips\nif (productImages.length === 0) {\n  return [{\n    json: {\n      submissionId: submissionId,\n      submissionFolderId: submissionFolderId,\n      consolidatedSpec: consolidatedSpec,\n      notes: notes,\n      imageCount: 0,\n      noImages: true,\n    },\n    pairedItem: { item: 0 },\n  }];\n}\n\n// Create one output item per image\nconst items = productImages.map((img, idx) => ({\n  json: {\n    submissionId: submissionId,\n    submissionFolderId: submissionFolderId,\n    consolidatedSpec: consolidatedSpec,\n    notes: notes,\n    imageIndex: idx,\n    filename: img.filename || `image_${idx}.jpg`,\n    mimeType: img.mimeType || 'image/jpeg',\n    binaryKey: img.binaryKey || null,\n  },\n  pairedItem: { item: 0 },\n}));\n\nreturn items;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -16,
        0
      ],
      "id": "5adaf065-0832-4d4d-8ac7-8deef614ba4e",
