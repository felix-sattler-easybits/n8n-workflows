      "name": "Sticky Note1"
    },
    {
      "parameters": {
        "content": "## 🚦 Route by Action\nSwitches on `action_id`. `save_to_sheet` goes to the Sheet append path. `dismiss` goes straight to card deletion. Any future action IDs (e.g. send-to-ATS) would slot in here.",
        "height": 416,
